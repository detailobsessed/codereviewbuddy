# Environment variables for codereviewbuddy
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
#
# .envrc (direnv) sources this file automatically if you add `dotenv` to it.
# See: https://direnv.net/man/direnv-stdlib.1.html

# --- codereviewbuddy settings ------------------------------------------------

# Enable agent-driven self-improvement feedback loop (default: false)
# CRB_SELF_IMPROVEMENT__ENABLED=true

# GitHub usernames considered "ours" for triage filtering (comma-separated)
# CRB_OWNER_LOGINS=alice,bob

# Enable/disable PR description review tools (default: true)
# CRB_PR_DESCRIPTIONS__ENABLED=true
